# Supabase Realtime self-host — V97.39.33
# Copie en `.env` sur le VPS et remplis.

# === DB connection ===
# Password du rôle supabase_realtime_admin (créé par scripts/init-realtime-role.sql)
REALTIME_DB_PASSWORD=<openssl rand -base64 32>

# === Encryption ===
# Clé de chiffrement utilisée pour stocker les tenant secrets en DB
# (single tenant mais le soft chiffre quand même). Exactement 16 chars.
REALTIME_ENC_KEY=<openssl rand -hex 8>

# Phoenix secret_key_base (signe les WS tokens internes). Min 64 chars.
REALTIME_SECRET_KEY_BASE=<openssl rand -hex 32>

# === JWT (DOIT être identique à POSTGREST_JWT_SECRET dans tools/postgrest-vps/.env)
POSTGREST_JWT_SECRET=<same as postgrest-vps/.env>
