# Worker Zendriver — variables d'environnement
# Copier ce fichier vers .env et remplir les valeurs.

# Bearer token partagé Vercel ↔ Worker. Générer avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
FETCHER_TOKEN=

# Hosts autorisés pour le scraping. Le worker rejette toute autre URL.
# Format : liste séparée par virgules, sans http://, sans www.
ALLOW_HOSTS=leboncoin.fr,seloger.com,logic-immo.com

# Taille du pool de browsers Zendriver tenus warm.
# 3 = équilibre entre RAM (~3GB) et latence cold-start évitée.
POOL_SIZE=3

# Timeout max par fetch en millisecondes (clampé entre 1000-30000 côté worker).
DEFAULT_MAX_WAIT_MS=15000

# Rate-limit par IP source (sliding window 1h).
RATE_LIMIT_PER_HOUR=60

# Optionnel : URL callback Vercel pour notifier la fin d'un job (async pattern).
# Si fourni, le worker POSTera { job_id, status, html, error } vers cette URL.
# Sinon, le worker répond synchronement à /fetch.
CALLBACK_URL=
CALLBACK_TOKEN=

# Logs verbosité (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Bind address (laisser localhost car Caddy fait le reverse-proxy).
HOST=127.0.0.1
PORT=8080

# ─────────────────────────────────────────────────────────────────────────
# Proxy résidentiel optionnel (V97.39.10)
# ─────────────────────────────────────────────────────────────────────────
# Pour bypasser DataDome qui flag l'ASN OVHcloud comme "datacenter",
# router le trafic Zendriver via un proxy résidentiel. Sans proxy le bypass
# reste à 0% sur LBC/SeLoger/Logic-immo malgré toutes les optimisations.
#
# Providers compatibles (testés en 2026) :
#  - Webshare.io     : free tier 10 proxies rotatifs 1GB/mois, puis ~1$/GB
#                      Format : http://USER:PASS@p.webshare.io:80
#  - Bright Data     : 300$/mois résidentiel premium (très cher mais 95%+)
#  - IPRoyal         : 7$/GB résidentiel, pas de free tier
#  - Smartproxy      : pareil, $7-10/GB
#
# Pour activer :
#   1. Créer un compte sur le provider, récupérer credentials
#   2. Décommenter et remplir WORKER_PROXY_URL ci-dessous
#   3. (optionnel) WORKER_PROXY_USERNAME + WORKER_PROXY_PASSWORD si auth séparée
#   4. sudo docker compose restart
#   5. Surveiller `/admin/imports` pour voir si succès rate augmente
#
# Format URL : "http://user:pass@host:port" OU "socks5://user:pass@host:port"
# Laisser vide pour désactiver (default).
WORKER_PROXY_URL=
WORKER_PROXY_USERNAME=
WORKER_PROXY_PASSWORD=
