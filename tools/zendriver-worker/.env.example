# Worker Zendriver — variables d'environnement
# Copier ce fichier vers .env et remplir les valeurs.

# Bearer token partagé Vercel ↔ Worker. Générer avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
FETCHER_TOKEN=

# Hosts autorisés pour le scraping. Le worker rejette toute autre URL.
# Format : liste séparée par virgules, sans http://, sans www.
ALLOW_HOSTS=leboncoin.fr,seloger.com,logic-immo.com

# Taille du pool de browsers Zendriver tenus warm.
# 3 = équilibre entre RAM (~3GB) et latence cold-start évitée.
POOL_SIZE=3

# Timeout max par fetch en millisecondes (clampé entre 1000-30000 côté worker).
DEFAULT_MAX_WAIT_MS=15000

# Rate-limit par IP source (sliding window 1h).
RATE_LIMIT_PER_HOUR=60

# Optionnel : URL callback Vercel pour notifier la fin d'un job (async pattern).
# Si fourni, le worker POSTera { job_id, status, html, error } vers cette URL.
# Sinon, le worker répond synchronement à /fetch.
CALLBACK_URL=
CALLBACK_TOKEN=

# Logs verbosité (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Bind address (laisser localhost car Caddy fait le reverse-proxy).
HOST=127.0.0.1
PORT=8080
