# GlitchTip self-host — V97.39.34
# Copie en `.env` sur le VPS.

# DB Postgres (rôle dédié glitchtip, créé par scripts/init-db.sh)
# Préfère -hex (pas -base64) pour éviter `/` dans DATABASE_URL
GLITCHTIP_DB_PASSWORD=<openssl rand -hex 32>

# Django SECRET_KEY (>= 50 chars random)
GLITCHTIP_SECRET_KEY=<openssl rand -base64 64>

# Brevo (pour emails alertes Sentry — réutilise Phase 5)
BREVO_API_KEY=<même clé que /etc/keymatch-prod.env>
