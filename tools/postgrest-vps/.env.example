# PostgREST self-host — V97.39.33
# Copie en `.env` sur le VPS et remplis les valeurs.

# === DB connection ===
# Rôle dédié PostgREST (créé par scripts/init-roles.sql).
# NON le superuser keymatch — PostgREST switche vers anon/authenticated/
# service_role selon le JWT.
POSTGREST_DB_USER=authenticator
POSTGREST_DB_PASSWORD=<openssl rand -base64 32 — ne pas committer>

# === JWT auth ===
# Secret HS256 partagé entre PostgREST et le code Next.js.
# IMPORTANT : ce secret signe les ANON_KEY + SERVICE_ROLE_KEY.
# Min 32 chars.
POSTGREST_JWT_SECRET=<openssl rand -base64 48 — ne pas committer>

# === Clés générées par scripts/generate-keys.sh ===
# (sortie du script, à reporter dans /etc/keymatch-prod.env)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
