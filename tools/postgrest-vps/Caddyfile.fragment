# Caddyfile fragment — V97.39.33 Phase 7 KeyMatch
# À ajouter dans /etc/caddy/Caddyfile sur le VPS.
#
# Expose PostgREST + Supabase Realtime self-host derrière db.keymatch-immo.fr
# avec TLS Let's Encrypt automatique.
#
# Compat Supabase :
#  - SDK envoie ?apikey=<jwt> OU header "apikey: <jwt>" OU "Authorization: Bearer <jwt>"
#  - PostgREST 12+ lit Authorization par défaut. Caddy rewrite apikey → Authorization
#    pour les requêtes qui n'ont pas déjà Authorization.

db.keymatch-immo.fr {
    # Logs séparés pour debug cutover
    log {
        output file /var/log/caddy/keymatch-db.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }

    # === Header normalization Supabase → PostgREST ===
    # Le SDK envoie "apikey: <JWT>". On rewrite vers Authorization si absent.
    # IMPORTANT : `request_header` doit être au niveau racine (pas dans un
    # `handle`) sinon il devient terminal et bloque le routing vers PostgREST.
    @no_auth {
        not header Authorization *
        header apikey *
    }
    request_header @no_auth Authorization "Bearer {http.request.header.apikey}"

    # === REST API (PostgREST) ===
    # Supabase format : /rest/v1/<table>
    # PostgREST format : /<table>
    # → strip /rest/v1 prefix
    # Note : reverse_proxy à `localhost:3000` car Caddy tourne en host
    # systemd (pas dans Docker), il ne peut pas résoudre les hostnames Docker.
    # PostgREST bind 127.0.0.1:3000 via docker-compose (V97.39.33).
    handle_path /rest/v1/* {
        reverse_proxy localhost:3000 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
            transport http {
                keepalive 30s
            }
        }
    }

    # === Realtime WebSocket ===
    # Supabase SDK construit l'URL `wss://<host>/realtime/v1/websocket` mais
    # supabase/realtime (Phoenix) expose le WS à `/socket/websocket`. Caddy
    # rewrite le path avant de proxy.
    #
    # IMPORTANT : NE PAS ajouter `header_up Connection {>Connection}` ni
    # `header_up Upgrade {>Upgrade}` — Caddy gère le WebSocket upgrade
    # automatiquement, et ces directives explicites BREAK le passthrough
    # (résultat : 400 Bad Request). Laisser reverse_proxy nu (validé en
    # prod 2026-05-18 : WS 101 OK).
    handle /realtime/v1/* {
        rewrite * /socket/websocket
        reverse_proxy localhost:4000
    }

    # === Storage (proxy vers MinIO) ===
    # Optionnel : si on veut servir media.keymatch-immo.fr aussi depuis db.keymatch-immo.fr/storage/v1
    # Pas branché par défaut, dossier-photo continue de pointer media.keymatch-immo.fr.

    # === Health check (sans auth) ===
    handle /health {
        respond "OK - keymatch-db {time.now}" 200
    }

    # === Default : 404 explicite ===
    handle {
        respond "Not found - try /rest/v1/* or /realtime/v1/*" 404
    }

    # Headers sécurité
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        # CORS pour le browser direct (SDK Supabase côté client)
        Access-Control-Allow-Origin "https://keymatch-immo.fr"
        Access-Control-Allow-Credentials "true"
        Access-Control-Allow-Methods "GET, POST, PATCH, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Authorization, Content-Type, apikey, Prefer, Accept, Range, X-Client-Info"
        -Server
    }

    # Preflight CORS
    @options method OPTIONS
    handle @options {
        respond 204
    }
}
