# MinIO KeyMatch — variables d'env Phase 3
# Copier vers .env (gitignored), remplir avec les vrais creds.

# Root creds MinIO. ⚠ Ne JAMAIS commit en clair.
# Génère un mdp solide :
#   openssl rand -base64 32
MINIO_ROOT_USER=keymatch
MINIO_ROOT_PASSWORD=

# URLs Caddy reverse-proxy (utilisé par MinIO pour les redirects + signed URLs)
# En dev local :
#   MINIO_SERVER_URL=http://localhost:9000
#   MINIO_CONSOLE_URL=http://localhost:9001
# En prod VPS derrière Caddy :
#   MINIO_SERVER_URL=https://media.keymatch-immo.fr
#   MINIO_CONSOLE_URL=https://media-admin.keymatch-immo.fr
MINIO_SERVER_URL=http://localhost:9000
MINIO_CONSOLE_URL=http://localhost:9001

# Credentials Supabase pour le script de migration (scripts/migrate-from-supabase.sh)
# Récupère depuis nestmatch/.env.local. Ces vars ne sont utilisées QUE par le script
# one-shot de migration data — pas par MinIO lui-même.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Phase 8 backup integration ──────────────────────────────────
# MinIO data va être inclus dans le backup-daily.sh via tar du volume.
# Pas de var à set ici : c'est /srv/keymatch/minio-data/ qui est tarball-é
# par tools/postgres-vps/scripts/backup-daily.sh ligne X (à wirer).
