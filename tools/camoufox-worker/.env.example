# KeyMatch Camoufox Worker — V97.39.34 P3-7
# Copie en `.env` sur Oracle Cloud VM.

# === Auth ===
# Bearer token unique partagé KeyMatch (Vercel/VPS) ↔ Worker.
# Génère : openssl rand -hex 32
FETCHER_TOKEN=<openssl rand -hex 32>

# === Allowlist (anti-SSRF) ===
# Domaines autorisés. Le worker bloque tout autre host.
ALLOW_HOSTS=leboncoin.fr,seloger.com,logic-immo.com

# === Pool ===
POOL_SIZE=3                      # 3 contextes warm Camoufox (~2.5 GB RAM total)
DEFAULT_MAX_WAIT_MS=25000        # DataDome challenge prend 3-10s, marge confortable

# === Rate-limit ===
RATE_LIMIT_PER_HOUR=60           # par IP source

# === Callback async (mode polling) ===
# Si le worker reçoit un body avec `job_id`, il fait le fetch en background
# et POST le résultat ici (KeyMatch route /api/proprio/annonce/import/callback).
# Le worker token côté KeyMatch valide le Bearer.
CALLBACK_URL=https://keymatch-immo.fr/api/proprio/annonce/import/callback
CALLBACK_TOKEN=<openssl rand -hex 32>   # token séparé worker → KeyMatch

# === Proxy résidentiel (optionnel) ===
# Si DataDome bloque l'ASN Oracle Cloud comme il bloque OVH, ajoute :
# WORKER_PROXY_URL=http://user:pass@proxy.webshare.io:80
# WORKER_PROXY_USERNAME=
# WORKER_PROXY_PASSWORD=
# Coût : Webshare ~$1/GB, 1 GB = ~2000 imports. Ou Bright Data ~$15/GB pour
# meilleur taux. Reporté hors-scope V1.

# === Logs ===
LOG_LEVEL=INFO

# === Bind ===
HOST=127.0.0.1                   # Cloudflared tunnel pull localhost
PORT=8080
