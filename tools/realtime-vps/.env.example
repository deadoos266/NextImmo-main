# KeyMatch realtime — variables d'env Phase 4
# Copier vers .env (gitignored), remplir avec les vrais creds.

# Postgres self-host VPS (Phase 2). Le service LISTEN dessus.
# Format : postgresql://keymatch:PASS@keymatch-postgres:5432/keymatch
# Doit pointer vers le container postgres (hostname Docker network).
DATABASE_URL=

# NextAuth secret. MÊME valeur que côté Next.js. Sert à vérifier les JWT
# qui arrivent dans le handshake socket.io.
NEXTAUTH_SECRET=

# Origines autorisées CORS. Comma-separated. Inclure prod + staging + dev.
ALLOWED_ORIGINS=https://keymatch-immo.fr,https://staging.keymatch-immo.fr,http://localhost:3000

# Port + host (défauts OK pour Docker)
PORT=3001
HOST=0.0.0.0
