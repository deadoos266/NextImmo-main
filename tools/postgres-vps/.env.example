# Postgres KeyMatch — variables d'env
# Copier vers .env (qui est gitignored) et remplir.

POSTGRES_USER=keymatch
POSTGRES_DB=keymatch

# Mot de passe Postgres — GÉNÉRER avec :
#   openssl rand -base64 32
# Ne JAMAIS commit ce fichier en clair. PgBouncer + Vercel utilisent ce password.
POSTGRES_PASSWORD=

# URL Supabase (source de la migration) — copier depuis nestmatch/.env.local
# Format : postgresql://postgres.<ref>:<password>@<host>:5432/postgres
# Trouvable dans Supabase Dashboard → Project Settings → Database → Connection String
SUPABASE_DB_URL=

# ─── Phase 8 Backups (optionnel mais recommandé) ─────────────────────────
# RCLONE_REMOTE : remote rclone (lance `rclone config` pour le créer)
#   Format : <remote-name>:<bucket-or-container-name>
#   Ex Backblaze : b2-keymatch:keymatch-backups
#   Ex OVH Object Storage : ovh-keymatch:keymatch-backups
# Si vide → backup local seulement (rotation 7 daily + 4 weekly + 12 monthly)
RCLONE_REMOTE=

# BACKUP_NOTIFY_EMAIL : email destinataire des notifications si backup fail
BACKUP_NOTIFY_EMAIL=tic3467@gmail.com

# RESEND_API_KEY : utilise la même clé que la prod KeyMatch
#   Récupère via Vercel env vars ou Resend dashboard
#   Sert UNIQUEMENT à envoyer les emails fail (pas l'envoi user-facing)
RESEND_API_KEY=
