# Postgres KeyMatch — variables d'env
# Copier vers .env (qui est gitignored) et remplir.

POSTGRES_USER=keymatch
POSTGRES_DB=keymatch

# Mot de passe Postgres — GÉNÉRER avec :
#   openssl rand -base64 32
# Ne JAMAIS commit ce fichier en clair. PgBouncer + Vercel utilisent ce password.
POSTGRES_PASSWORD=

# URL Supabase (source de la migration) — copier depuis nestmatch/.env.local
# Format : postgresql://postgres.<ref>:<password>@<host>:5432/postgres
# Trouvable dans Supabase Dashboard → Project Settings → Database → Connection String
SUPABASE_DB_URL=
