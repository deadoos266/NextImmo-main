[Unit]
Description=KeyMatch Postgres Backup Restore Test (mensuel)
After=network-online.target docker.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/opt/keymatch/NextImmo-main/tools/postgres-vps
ExecStart=/opt/keymatch/NextImmo-main/tools/postgres-vps/scripts/restore-test.sh
StandardOutput=append:/var/log/keymatch-backup-test.log
StandardError=append:/var/log/keymatch-backup-test.log
