# NestMatch — Variables d'environnement
# Copier ce fichier en .env.local et remplir avec les valeurs reelles.
# En prod : definir ces variables dans les Environment Variables Vercel.

# --- Google OAuth (NextAuth) ---
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# --- NextAuth ---
# Generer un secret aleatoire long (au moins 32 caracteres) :
#   openssl rand -base64 32
# ou sur https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=REMPLACER_PAR_UN_SECRET_ALEATOIRE_LONG
# URL publique de l'app (http://localhost:3000 en dev, https://ton-domaine.com en prod)
NEXTAUTH_URL=http://localhost:3000

# --- Supabase ---
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# ATTENTION : service_role key contourne la RLS. Ne jamais exposer cote client.
# Uniquement pour usage serveur (API routes).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Anthropic (agent IA) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx
