# KeyMatch — Variables d'environnement
# ═══════════════════════════════════════════════════════════════════
# Copier ce fichier en .env.local et remplir avec les valeurs reelles.
# En prod : definir ces variables dans les Environment Variables Vercel.
#
# Groupes :
#   1. Auth & session        (Google OAuth, NextAuth)
#   2. Base de donnees       (Supabase)
#   3. Emails transactionnels (Resend)
#   4. Rate-limit             (Upstash Redis)
#   5. Observabilite          (Sentry)
#   6. IA & agents            (Anthropic)
#   7. Misc                   (URL publique, flags beta/noindex, sel dossier)
# ═══════════════════════════════════════════════════════════════════


# ─── 1. Google OAuth (NextAuth) ───────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Autoriser les Redirect URIs :
#   http://localhost:3000/api/auth/callback/google
#   https://keymatch-immo.fr/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx


# ─── NextAuth ─────────────────────────────────────────────────────
# Generer un secret aleatoire long (au moins 32 caracteres) :
#   openssl rand -base64 32
# ou sur https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=REMPLACER_PAR_UN_SECRET_ALEATOIRE_LONG
# URL publique de l'app
NEXTAUTH_URL=http://localhost:3000


# ─── 2. Supabase ──────────────────────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# ATTENTION : service_role key contourne la RLS. Ne jamais exposer cote client.
# Uniquement pour usage serveur (API routes).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── 2b. Storage provider (Supabase Storage par defaut, MinIO en option) ──
#
# STORAGE_PROVIDER : choix du backend storage runtime (default = supabase)
#   - supabase : provider historique (avatars, photos, dossiers, baux, etc.)
#   - minio    : self-host sur VPS OVH, S3-compatible, 0€, RGPD-natif
# Phase 3 plan migration OVH : switcher en flippant cette env var.
# Cf docs/PHASE3_MINIO_SETUP.md pour la procedure d'activation MinIO.
STORAGE_PROVIDER=supabase
#
# MinIO env vars (Phase 3 — utilisees seulement si STORAGE_PROVIDER=minio)
# Pre-requis : tools/minio-vps deploye sur VPS + DNS media.keymatch-immo.fr
# Installer aussi les deps : npm install @aws-sdk/client-s3 @aws-sdk/s3-request-presigner
MINIO_ENDPOINT=https://media.keymatch-immo.fr
MINIO_PUBLIC_URL=https://media.keymatch-immo.fr
MINIO_ACCESS_KEY=keymatch
MINIO_SECRET_KEY=
MINIO_REGION=us-east-1

# ─── 2c. Realtime provider (Supabase Realtime par defaut, socket.io en option) ──
#
# NEXT_PUBLIC_REALTIME_PROVIDER : choix du backend realtime client (default = supabase)
#   - supabase : Supabase Realtime (postgres_changes channel)
#   - socketio : self-host socket.io sur VPS (Phase 4 plan migration OVH)
# Cf docs/PHASE4_REALTIME_SETUP.md pour la procedure d'activation.
NEXT_PUBLIC_REALTIME_PROVIDER=supabase
#
# socket.io self-host URL — utilise seulement si NEXT_PUBLIC_REALTIME_PROVIDER=socketio
# Pre-requis : tools/realtime-vps deploye + DNS ws.keymatch-immo.fr + migration 085
# Installer aussi : npm install socket.io-client
NEXT_PUBLIC_REALTIME_URL=wss://ws.keymatch-immo.fr


# ─── 3. Emails transactionnels (Resend par defaut, Brevo en option) ──
#
# EMAIL_PROVIDER : choix du provider runtime (default = resend).
#   - resend : provider historique, US-based, 100/day gratuits puis $20/mo
#   - brevo  : provider FR (ex-Sendinblue), 300/day gratuits a vie, RGPD-natif
# Phase 5 plan migration OVH : switcher en flippant cette env var.
# Cf docs/PHASE5_BREVO_SETUP.md pour la procedure d'activation Brevo.
EMAIL_PROVIDER=resend
#
# ─── 3a. Resend ──────────────────────────────────────────────────
# https://resend.com/api-keys
# Domaine verifie requis avant d'envoyer depuis noreply@keymatch-immo.fr
RESEND_API_KEY=re_xxxxxxxxxxxx
# Adresse expediteur par defaut (doit appartenir a un domaine verifie Resend).
# Fallback silencieux sur onboarding@resend.dev si absent (dev seulement).
RESEND_FROM_EMAIL=noreply@keymatch-immo.fr
# Nom affiche dans l'inbox (From: "KeyMatch" <noreply@...>)
RESEND_FROM_NAME=KeyMatch
# Optionnel : adresse Reply-To (support@...). Si absent, reply va a FROM_EMAIL.
RESEND_REPLY_TO=support@keymatch-immo.fr
#
# ─── 3b. Brevo (alternative RGPD-FR — Phase 5 migration OVH) ─────
# https://app.brevo.com/settings/keys/api (cree une API key v3)
# Pre-requis : domaine keymatch-immo.fr verifie dans Brevo
#   (Senders & IP > Domains > Add a domain > suivre DKIM/SPF/DMARC OVH)
# Active en mettant EMAIL_PROVIDER=brevo ci-dessus.
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
BREVO_FROM_EMAIL=noreply@keymatch-immo.fr
BREVO_FROM_NAME=KeyMatch
# Optionnel : reply-to Brevo. Si absent, reply va a FROM_EMAIL.
BREVO_REPLY_TO=support@keymatch-immo.fr


# ─── 4. Upstash Redis (rate-limit) ───────────────────────────────
# https://console.upstash.com/redis
# Sans ces 2 vars, le rate-limit tombe silencieusement en "process-local"
# (Map en memoire) — OK en dev, KO en prod multi-instance.
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxx


# ─── 5. Sentry (observabilite) ───────────────────────────────────
# https://sentry.io/settings/<org>/projects/<project>/keys/
# DSN server-side (API routes + server components) — secret
SENTRY_DSN=https://xxxxxxxxxxxx@o0.ingest.sentry.io/0
# DSN client-side (identique au server DSN, mais expose au navigateur)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxx@o0.ingest.sentry.io/0
# Slug org Sentry (ex: "keymatch") — utilise par @sentry/nextjs a la build
SENTRY_ORG=keymatch
# Slug project Sentry (ex: "nestmatch-web")
SENTRY_PROJECT=nestmatch-web
# Token Sentry pour upload des source maps au build (scope project:releases).
# A NE PAS mettre dans .env.local : c'est un secret de build Vercel uniquement,
# cote Production seulement (evite d'uploader sur les previews PR = explosion quota).
# https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx


# ─── 6. Anthropic (agents IA Opus/Sonnet) ────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx


# ─── 7. Misc ─────────────────────────────────────────────────────
# URL publique canonique de l'app — utilisee dans emails, sitemap, OG images,
# redirections auth. En dev, laisser http://localhost:3000.
# En prod Vercel : https://keymatch-immo.fr
NEXT_PUBLIC_URL=http://localhost:3000

# Mode beta : bloque l'indexation Google (robots.txt + meta robots).
# A activer en preview / staging. A retirer au lancement public.
NEXT_PUBLIC_NOINDEX=false

# Banniere beta en haut de page (BetaBanner.tsx). Activer pour signaler
# l'etat beta aux premiers utilisateurs.
NEXT_PUBLIC_BETA=false

# Sel HMAC pour hasher les IP et tokens dans dossier_access_log.
# RGPD : on ne stocke JAMAIS l'IP brute. Generer un sel long aleatoire :
#   openssl rand -hex 32
# NE JAMAIS changer en prod apres mise en service (invaliderait les hashes).
DOSSIER_LOG_SALT=REMPLACER_PAR_UN_SEL_ALEATOIRE_LONG

# Optionnel : analyze bundle avec @next/bundle-analyzer. Dev only.
#   ANALYZE=true npm run build
# ANALYZE=false


